# GAS Web App のデプロイURL（末尾に /exec が付いた形式）
NEXT_PUBLIC_GAS_API_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# 休暇申請用 GAS Web App のデプロイURL（休暇申請既存ツール.gs をデプロイしたURL）
NEXT_PUBLIC_LEAVE_GAS_API_URL=https://script.google.com/macros/s/YOUR_LEAVE_DEPLOYMENT_ID/exec

# OpenAI API Key（AI自動チェック・領収書OCR用・画像のみ）
OPENAI_API_KEY=sk-proj-xxxxx

# Google Gemini API Key（PDF領収書のAIチェック用。画像はOpenAIを使用）
GOOGLE_GEMINI_API_KEY=

# Supabase（承認履歴・コメント用。MVP ではサーバー側のみ使用）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Firebase Admin（ログイン時のトークン検証）
# 推奨: Firebase コンソールでダウンロードした JSON を firebase-service-account.json として保存し、
#       プロジェクトルートに置いて以下を有効にする（.gitignore 済み）
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=firebase-service-account.json
# 上記を使わない場合のみ: FIREBASE_SERVICE_ACCOUNT_KEY に「1行にした」JSON 文字列を設定（改行不可）

# ログイン許可（いずれかで許可）。BigQuery 未設定時は ALLOWED_LOGIN_EMAILS 必須（カンマ区切りで複数可）
# ALLOWED_LOGIN_EMAILS=your@gmail.com,other@example.com
# ALLOWED_DEPARTMENTS=経理部,開発部
# ALLOWED_ROLE=管理者

# 請求書の承認・差し戻しが可能な所属・役職（いずれかに該当で承認可能。未設定時は「経理」「役員」）
# INVOICE_APPROVER_DEPARTMENTS=経理
# INVOICE_APPROVER_ROLES=役員

# 役員担当として扱う担当者名（カンマ区切り）。該当する請求書は役員・経理のみ一覧・詳細表示。
# 未設定の場合は役員担当の絞り込みは行われず、全員に表示されます。担当者名は DB（chatwork_assignees）の表記と一致させること。
# 役員: 廣瀬 崚ニ, 藤原 瑞基, 小山 亮, 潮崎 由愛, 國場 義功 ／ 経理: 西野 沙紀, 甲斐 忍（承認可否は INVOICE_APPROVER_* の所属・役職で判定）
# INVOICE_EXECUTIVE_SUBMITTER_NAMES=廣瀬 崚ニ,藤原 瑞基,小山 亮,潮崎 由愛,國場 義功

# 開発時のみ: Firebase をスキップし「開発用ログイン」を表示（本番では未設定にすること）
# DEV_SKIP_FIREBASE_AUTH=true
# NEXT_PUBLIC_DEV_SKIP_FIREBASE_AUTH=true

# セッション署名用（32文字以上必須）。dev-login でも必要
# AUTH_SECRET=your-random-secret-at-least-32-chars

# アプリのベースURL（Chatwork 差し戻し通知の「確認」リンクに使用。未設定時は tmg-settlement.vercel.app）
# NEXT_PUBLIC_APP_URL=https://tmg-settlement.vercel.app

# Chatwork（請求書「経理へ提出」・差し戻し時にルームへ通知。未設定時は通知しない）
# CHATWORK_API_TOKEN=your-chatwork-api-token
# CHATWORK_ROOM_ID=273335165
# CHATWORK_TO_IDS=2770625,9991262

